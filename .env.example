# Project Manager Environment Variables
# Copy this file to .env.local and update values

# Database
# For SQLite (development): file:./prisma/dev.db
# For PostgreSQL: postgresql://user:password@localhost:5432/project_manager
DATABASE_URL="file:./prisma/dev.db"

# NextAuth Configuration
NEXTAUTH_SECRET="your-secret-key-here-min-32-characters-long"
NEXTAUTH_URL="http://localhost:3000"

# OAuth Providers (optional)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Google Drive API (optional, for asset sync)
GOOGLE_DRIVE_FOLDER_ID="your-google-drive-folder-id"

# Email Configuration (optional, for email integration)
EMAIL_FROM="noreply@yourapp.com"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-specific-password"

# Slack Integration (optional)
SLACK_BOT_TOKEN="your-slack-bot-token"
SLACK_WEBHOOK_URL="your-slack-webhook-url"
